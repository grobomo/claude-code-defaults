{
  "env": {},
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(gh *)",
      "Edit",
      "Write",
      "Read",
      "Glob",
      "Grep",
      "Bash(python *)",
      "Bash(npm *)",
      "Bash(node *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(mkdir *)",
      "Bash(rm *)",
      "Bash(cp *)",
      "Bash(mv *)"
    ],
    "deny": [
      "Agent"
    ],
    "defaultMode": "bypassPermissions"
  },
  "model": "opus",
  "enableAllProjectMcpServers": true,
  "enabledPlugins": {},
  "autoUpdatesChannel": "latest",
  "voiceEnabled": false,
  "skipDangerousModePermissionPrompt": true
}
